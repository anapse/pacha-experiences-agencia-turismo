# Backend Configuration
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=pacha-jwt-secret-change-in-production
JWT_REFRESH_SECRET=pacha-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./database/data.sqlite

# CORS
CORS_ORIGIN=http://localhost:5173

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pacha-experiences.com

# Upload
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=5242880

# App
APP_NAME=Pacha Experiences
APP_URL=http://localhost:5173
API_URL=http://localhost:3001/api
